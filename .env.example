# ── Frontend (Vite - exposed to client) ──────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# ── PostHog Analytics ─────────────────────────────────────────────
VITE_POSTHOG_KEY=your-posthog-project-key
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_ENABLE_ANALYTICS_DEV=false
VITE_ANALYTICS_BLOCKED_EMAILS=user1@example.com,user2@example.com

# ── Supabase Edge Functions (server-side only) ───────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenWA Self-Hosted WhatsApp API ─────────────────────────────
OPENWA_API_URL=http://localhost:2785
OPENWA_API_KEY=your-openwa-api-key
OPENWA_SESSION_ID=your-session-id

# ── Mistral AI Chatbot ───────────────────────────────────────────
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-large-latest

# ── Cron Security ────────────────────────────────────────────────
CRON_SECRET=your-cron-secret

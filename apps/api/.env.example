# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# API Security (optional — used for cron endpoint only)
API_SECRET=your-secure-random-api-key-here

# NVIDIA AI (optional — chat falls back to keyword matching)
NVIDIA_API_KEY=nvapi-your-key-here

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Webhook
WEBHOOK_VERIFY_TOKEN=aquaops-verify-2024
